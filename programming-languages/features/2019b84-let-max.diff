+        (max-exp (identifier)
+          (letrec
+            (
+              (num-val?
+                (lambda (v)
+                  (cases expval v
+                    (num-val (num) #t)
+                    (else #f)
+                  )
+                )
+              )
+              (max-loop
+                (lambda (env search-sym)
+                  (if (empty-env? env)
