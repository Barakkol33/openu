\begin_inset Formula $\lambda_{1}\sin x+\lambda_{2}\cos x=\boldsymbol{0}$
\end_inset

 כאשר 
\begin_inset Formula $\lambda_{1},\lambda_{2}\in\kaliReal$
\end_inset

 הוא הפתרון הטריוויאלי )ו-
\begin_inset Formula $\boldsymbol{0}$
\end_inset

 היא פונקציית האפס(.
\end_layout

\begin_layout Standard
נניח שמתקיים 
\begin_inset Formula $\lambda_{1}=0$
\end_inset

 או 
\begin_inset Formula $\lambda_{2}=0$
\end_inset

.
 אם כך, במשוואה יש רק וקטור אחד ולכן הוא בלתי תלוי לינארית.
\end_layout

\begin_layout Standard
כעת נניח שמתקיים 
\begin_inset Formula $\lambda_{1}\neq0$
\end_inset

 וגם 
\begin_inset Formula $\lambda_{2}\neq0$
\end_inset

:
\end_layout

\begin_layout Standard
\align left
\begin_inset Formula $\lambda_{1}\sin x+\lambda_{2}\cos x=\boldsymbol{0}$
\end_inset


\end_layout

\begin_layout Standard
\align left
\begin_inset Formula $\lambda_{1}\sin x=-\lambda_{2}\cos x$
\end_inset


\end_layout

\begin_layout Standard
\align left
\begin_inset Formula $\lambda_{1}^{2}\sin^{2}x=\lambda_{2}^{2}\cos^{2}x$
\end_inset


\end_layout

\begin_layout Standard
ידוע שמתקיים 
\begin_inset Formula $\sin^{2}x+\cos^{2}x=1$
\end_inset

 ולכן:
\end_layout

\begin_layout Standard
\align left
\begin_inset Formula $\lambda_{1}^{2}\sin^{2}x=\lambda_{2}^{2}\left(1-\sin^{2}x\right)=\lambda_{2}^{2}-\lambda_{2}^{2}\sin^{2}x$
\end_inset


\end_layout

\begin_layout Standard
\align left
\begin_inset Formula $\sin x=\pm\sqrt{\frac{\lambda_{2}^{2}}{\lambda_{1}^{2}+\lambda_{2}^{2}}}$
\end_inset


\end_layout

\begin_layout Standard
אמנם, ידוע כי 
\begin_inset Formula $\sin x$
\end_inset

 היא אינה פונקציה קבועה, ולכן הגענו לסתירה.
 
\end_layout

\begin_layout Standard
אם כך, הוכחנו ש-
\begin_inset Formula $\sin x,\cos x$
\end_inset

 הם איברים בלתי תלויים לינארית במרחב 
\begin_inset Formula $V$
\end_inset

.
\end_layout

