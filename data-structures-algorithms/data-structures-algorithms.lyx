\begin_layout Itemize
\begin_inset Formula $1=\Theta\left(n^{\frac{1}{\lg n}}\right)$
\end_inset

: מתקיים 
\begin_inset Formula $n^{\frac{1}{\lg n}}=n^{\frac{\lg2}{\lg n}}=n^{\log_{n}2}=2$
\end_inset

 וכמובן הקשר מתקיים.
\end_layout

\begin_layout Itemize
\begin_inset Formula $1=\Omega\left(\lg\lg^{\ast}n\right)$
\end_inset

: אם נבחר 
\begin_inset Formula $c_{0}=1$
\end_inset

 אז הטענה מתקיים באופן טריוויאלי.
\end_layout

\begin_layout Itemize
\begin_inset Formula $\lg\lg^{\ast}n=\Omega\left(\lg^{\ast}n\right)$
\end_inset

: נסמן 
\begin_inset Formula $t=\lg^{\ast}n$
\end_inset

 ונקבל 
\begin_inset Formula $c\lg t\leq t$
\end_inset

.
 מתקיים 
\begin_inset Formula $\lim_{x\rightarrow\infty}\frac{x}{\lg x}=\infty$
\end_inset

 ולכן הטענה נכונה.
\end_layout

\begin_layout Itemize
\begin_inset Formula $:\lg^{\ast}n=\Theta\left(\lg^{\ast}\lg n\right)$
\end_inset

 ההפרש בערך מוחלט בין 
\begin_inset Formula $\lg^{\ast}\lg n$
\end_inset

 ל-
\begin_inset Formula $\lg^{\ast}n$
\end_inset

 הוא אחד ולכן ניתן למצוא קבועים המקיימים את הקשר 
\begin_inset Formula $\Theta\left(\right)$
\end_inset

.
\end_layout

\begin_layout Itemize
\begin_inset Formula $\lg^{\ast}n=\Omega\left(2^{\lg^{\ast}n}\right)$
\end_inset

: נסמן 
\begin_inset Formula $t=\lg^{\ast}n$
\end_inset

 ונקבל 
\begin_inset Formula $c_{0}t\leq2^{t}$
\end_inset

, ועבור 
\begin_inset Formula $c_{0}=1$
\end_inset

 זו טענה נכונה.
\end_layout

\begin_layout Itemize
\begin_inset Formula $\ln\ln n=\Omega\left(\sqrt{\lg n}\right)$
\end_inset

: אם נסמן 
\begin_inset Formula $t=\ln n$
\end_inset

 ונבצע מעבר בסיסים נקבל את הביטוי 
\begin_inset Formula $f\left(x\right)=\frac{1}{\sqrt{\ln2}}\sqrt{t}-c\ln t\geq0$
\end_inset

.
 עבור 
\begin_inset Formula $4\leq n_{0},c_{0}=1$
\end_inset

 פונקציה זו חיובית )ניתן להוכיח על ידי גזירה(.
 ולכן הטענה נכונה.
 
\end_layout

\begin_layout Itemize
\begin_inset Formula $\sqrt{\lg n}=\Omega\left(\ln n\right)$
\end_inset

: שקול לביטוי 
\begin_inset Formula $\sqrt{\ln n}\left(\sqrt{\ln n}-\frac{c_{0}}{\sqrt{\ln2}}\right)\geq0$
\end_inset

 והוא אמיתי עבור 
\begin_inset Formula $4\leq n_{0},c_{0}=1$
\end_inset

.
\end_layout

\begin_layout Itemize
\begin_inset Formula $\ln n=\Omega\left(\lg^{2}n\right)$
\end_inset

: שקול לביטוי 
\begin_inset Formula $\ln n\left(\frac{1}{\ln^{2}n}\ln n-c_{0}\right)\geq0$
\end_inset

 והוא אמיתי עבור 
\begin_inset Formula $2\leq n_{0},c_{0}=1$
\end_inset

.
\end_layout

\begin_layout Itemize
\begin_inset Formula $\ln n=\Omega\left(\lg^{2}n\right)$
\end_inset

: 
\begin_inset Formula $\lg^{2}n=\frac{\ln^{2}n}{\ln^{2}2}$
\end_inset

 ולכן הקשר בין שתי פונקציות אלו הוא כמו הקשר בין 
\begin_inset Formula $n$
\end_inset

